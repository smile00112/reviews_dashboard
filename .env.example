DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/yandex_reviews
YANDEX_OPERATOR_LOGIN=
YANDEX_OPERATOR_PASSWORD=
YANDEX_STORAGE_STATE_PATH=.local/yandex-storage-state.json
SCRAPER_DEBUG_DIR=.local/scraper-debug
NEXT_PUBLIC_API_URL=http://localhost:8000
# Control panel (feature 008): the web app proxies /api/* to this backend so the
# admin session cookie stays same-origin. Defaults to http://localhost:8000.
API_PROXY_URL=http://localhost:8000
# Admin panel (feature 004) — also used by the feature-008 control-panel login.
ADMIN_SECRET_KEY=change-me-in-production
SESSION_MAX_AGE=43200
# ScrapeOps proxy scraper (feature 005) — get key at scrapeops.io
SCRAPEOPS_API_KEY=
# 2GIS reviews (feature 006). Defaults are the public 2GIS web-client keys; override
# only to rotate if blocked. Short-link (go.2gis.com) resolution reuses SCRAPEOPS_API_KEY.
TWOGIS_CATALOG_KEY=rubnkm7490
TWOGIS_REVIEW_KEY=6e7e1929-4ea9-4a5d-8c05-d601860389bd
# Rotating proxy pool — primary transport for 2GIS (replaces exhausted ScrapeOps).
# Comma-separated scheme://user:pass@host:port; a port RANGE p1-p2 expands to one
# proxy per port. Scheme defaults to http:// — use socks5:// for SOCKS5 proxies
# (requires PySocks). Example: socks5://user:pass@pool.proxys.io:10000-10022
PROXY_POOL=
# CORS (feature 010): fail-closed — an EMPTY list aborts API startup (no silent
# '*' fallback with credentials). Comma-separated origins; default is the web app.
API_CORS_ORIGINS=http://localhost:3000
